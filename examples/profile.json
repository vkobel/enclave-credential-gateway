{
  "routes": {
    "anthropic": {
      "upstream": "https://api.anthropic.com",
      "inject_mode": "header",
      "credential_sources": [
        {"env": "ANTHROPIC_API_KEY", "inject_header": "Authorization", "format": "Bearer {}", "prefix": "sk-ant-oat"},
        {"env": "ANTHROPIC_API_KEY", "inject_header": "x-api-key",     "format": "{}"}
      ]
    },
    "openai": {
      "upstream": "https://api.openai.com",
      "inject_mode": "header",
      "credential_sources": [
        {"env": "OPENAI_API_KEY", "inject_header": "Authorization", "format": "Bearer {}"}
      ]
    },
    "github": {
      "upstream": "https://api.github.com",
      "inject_mode": "header",
      "alias": "api",
      "strip_prefix": "/api/v3",
      "credential_sources": [
        {"env": "GITHUB_TOKEN", "inject_header": "Authorization", "format": "Bearer {}"}
      ]
    },
    "httpbin": {
      "upstream": "https://httpbin.org",
      "credential_env": "HTTPBIN_TOKEN"
    }
  }
}