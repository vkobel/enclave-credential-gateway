{
  "routes": {
    "openai": {
      "upstream": "https://api.openai.com",
      "credential_sources": [
        {
          "env": "OPENAI_API_KEY",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "anthropic": {
      "upstream": "https://api.anthropic.com",
      "credential_sources": [
        {
          "env": "ANTHROPIC_API_KEY",
          "inject_header": "Authorization",
          "format": "Bearer {}",
          "prefix": "sk-ant-oat"
        },
        {
          "env": "ANTHROPIC_API_KEY",
          "inject_header": "x-api-key",
          "format": "{}"
        }
      ]
    },
    "github": {
      "upstream": "https://api.github.com",
      "aliases": [
        {
          "prefix": "api",
          "strip_prefix": "/v3"
        }
      ],
      "git_protocol": {
        "upstream": "https://github.com",
        "credential_sources": [
          {
            "env": "GITHUB_TOKEN",
            "inject_header": "Authorization",
            "basic_user": "x-access-token"
          }
        ]
      },
      "credential_sources": [
        {
          "env": "GITHUB_TOKEN",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "httpbin": {
      "upstream": "https://httpbin.org",
      "credential_sources": [
        {
          "env": "HTTPBIN_TOKEN",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "ollama": {
      "upstream": "https://127.0.0.1:11434",
      "credential_sources": [
        {
          "env": "OLLAMA_API_KEY",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "telegram": {
      "upstream": "https://api.telegram.org",
      "inject_mode": "url_path",
      "url_path_prefix": "/bot",
      "credential_sources": [
        {
          "env": "TELEGRAM_BOT_TOKEN",
          "inject_header": "X-Unused",
          "format": "{}"
        }
      ]
    },
    "groq": {
      "upstream": "https://api.groq.com",
      "credential_sources": [
        {
          "env": "GROQ_API_KEY",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "together": {
      "upstream": "https://api.together.xyz",
      "credential_sources": [
        {
          "env": "TOGETHER_API_KEY",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "elevenlabs": {
      "upstream": "https://api.elevenlabs.io",
      "credential_sources": [
        {
          "env": "ELEVENLABS_API_KEY",
          "inject_header": "xi-api-key",
          "format": "{}"
        }
      ]
    }
  }
}
