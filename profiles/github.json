{
  "routes": {
    "github": {
      "upstream": "https://api.github.com",
      "inject_mode": "header",
      "credential_sources": [
        {
          "env": "GITHUB_TOKEN",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    },
    "api": {
      "upstream": "https://api.github.com",
      "inject_mode": "header",
      "strip_prefix": "/v3",
      "credential_sources": [
        {
          "env": "GITHUB_TOKEN",
          "inject_header": "Authorization",
          "format": "Bearer {}"
        }
      ]
    }
  }
}